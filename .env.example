# Copy to `.env`:  cp .env.example .env
# Compose loads this for crew-hub env + build args. Rebuild crew-hub after changing NEXT_PUBLIC_*.

# --- Crew Hub (required) ---
CREW_SESSION_SECRET=replace-with-a-long-random-secret-min-16-chars

# First-time access: open /login and use “Create administrator account” when no users exist.
# Unattended / CI seeding: set to 1 to create users from CREW_BOOTSTRAP_* / CREW_ADMIN_* / subcontractor env vars.
# CREW_SEED_FROM_ENV=1
#
# Optional: sync an existing user’s password from env on each start (recovery).
# CREW_ADMIN_EMAIL=admin@crew.local
# CREW_ADMIN_PASSWORD=
# CREW_ADMIN_PASSWORD_HASH='$2b$10$...'

# Subcontractor (sample password: demo)
CREW_SUBCONTRACTOR_EMAIL=demo@crew.local
CREW_SUBCONTRACTOR_PASSWORD_HASH='$2b$10$Hoe1a6g2C09So1J8qypHQuNN/Xjq9oRcLNNKSWmOqz5JnRjwCjMtO'

# Optional: primary bootstrap admin when `.data/users.json` is empty (username + email for sign-in / reset).
# CREW_BOOTSTRAP_USERNAME=admin
# CREW_BOOTSTRAP_EMAIL=admin@crew.local
# CREW_BOOTSTRAP_PASSWORD=your-password
# CREW_BOOTSTRAP_PASSWORD_HASH='$2b$10$...'

# Billing follow-up cron: GET /api/billing/cron/followups?token=...
CREW_BILLING_CRON_SECRET=replace-with-random-secret

# Password reset + billing send: nodemailer
# SMTP_HOST= SMTP_PORT=587 SMTP_FROM= SMTP_USER= SMTP_PASS=

# Public URL for links inside billing emails (optional)
# NEXT_PUBLIC_CREW_PUBLIC_URL=https://your-crew.example.com

# Host port (see docker-compose.yml)
# CREW_HUB_PORT=38471

# --- Whisper ASR (speech-to-text transcription) ---
# Internal Docker URL — crew-hub container → whisper-asr container (do not use 127.0.0.1 inside Docker).
# WHISPER_ASR_URL=http://whisper-asr:9000
# Host port for direct access to Whisper (optional)
# WHISPER_ASR_PORT=9000
# Model: tiny.en / base.en / small.en / medium.en — larger = more accurate, slower first-load
# WHISPER_ASR_MODEL=base.en

# --- Baked into crew-hub image ---
# synapse-admin UI (docker-compose service synapse-admin; default host port 18088). Not the raw Synapse “It works!” page on :8008.
NEXT_PUBLIC_SERVICE_SYNAPSE_URL=http://127.0.0.1:18088
# Element Web (Matrix client) embed for /comms. You can use a base URL or a deep link (e.g. `#/room/!roomid:server`).
# NEXT_PUBLIC_SERVICE_MATRIX_CLIENT_URL=http://127.0.0.1:8088
NEXT_PUBLIC_MATRIX_HOMESERVER_URL=http://127.0.0.1:8008
# Matrix: proxy /_matrix + /_synapse through the hub (fixes browser “fetch failed” / CORS). Baked at **docker build**.
# For local `npm run dev` / CLI scripts on the host, use localhost Synapse:
# MATRIX_UPSTREAM_URL=http://127.0.0.1:8008
# docker-compose.yml forces http://synapse:8008 for the crew-hub container (do not rely on 127.0.0.1 inside Docker).
# Optional: host port for synapse-admin (default 18088 if 8088 is already in use on your machine)
# SYNAPSE_ADMIN_PORT=18088

# iCal (Google Calendar → Add calendar → From URL). Same CREW_ICAL_TOKEN for:
#   /api/ical/combined — shifts + schedule events (recommended)
#   /api/ical/shifts — shifts only
#   /api/ical/calendar — schedule events only
# CREW_ICAL_TOKEN=
# CREW_ICAL_NAME=Crew Shifts
# CREW_COMBINED_ICAL_NAME=Crew Hub
# CREW_CALENDAR_ICAL_NAME=Crew Schedule
# If the admin “Manage shifts” link shows the wrong origin, set:
# NEXT_PUBLIC_CREW_PUBLIC_URL=https://your-crew.example.com

# --- Matrix / Synapse ---
# LAN + remote: use ONE Synapse; the hub proxies /_matrix to MATRIX_UPSTREAM_URL. Open Crew at http://<LAN-IP>:<port>
# for offline/LAN Matrix, or at your HTTPS URL for remote — same accounts if it’s the same server/data.
# Two separate Synapse servers = two different Matrix domains (not the same @user:server accounts).
SYNAPSE_SERVER_NAME=localhost
SYNAPSE_REPORT_STATS=no
# Optional: Matrix room id (!roomid:server) — auto-select in /comms when joined (runtime env; no rebuild).
# CREW_MATRIX_DEFAULT_ROOM_ID=!xxxxxxxx:localhost

# Optional: when set, creating a user in Crew Hub (Admin → Users) also creates a Synapse account with the same
# username + password so Element can sign in while public registration stays disabled.
# Use a Synapse *server admin* access token (Element → Settings → Help & About → Access token).
# CREW_SYNAPSE_ADMIN_ACCESS_TOKEN=syt_xxxxxxxx
# Server name must match MXIDs (@user:domain) — defaults to SYNAPSE_SERVER_NAME above; override if needed:
# CREW_SYNAPSE_SERVER_NAME=localhost

# --- Matrix room blueprint — populate Synapse rooms from the Raconteur blueprint
# From repo root: npm run matrix:provision-rooms  (needs Synapse up, e.g. docker compose up -d synapse)
# The script loads this file. Host CLI: MATRIX_UPSTREAM_URL=http://127.0.0.1:8008
# Auth — pick one:
#   CREW_MATRIX_SEED_ACCESS_TOKEN=syt_...   # Element → Settings → Help → Access token
#   CREW_MATRIX_SEED_USER=raconteur CREW_MATRIX_SEED_PASSWORD=...   # existing @user:localhost
# Optional: CREW_SYNAPSE_ADMIN_ACCESS_TOKEN=syt_... (server admin) — creates/updates CREW_MATRIX_SEED_USER if missing
# CREW_SYNAPSE_SERVER_NAME=localhost   # defaults to SYNAPSE_SERVER_NAME if unset

# VDO.Ninja — Production video page (/comms/vdo); rebuild hub after changing NEXT_PUBLIC_*.
# Single URL:
# NEXT_PUBLIC_VDO_NINJA_URL=https://vdo.ninja
# LAN + internet (order matters): first = self-hosted / LAN IP:port, second = public or cloud instance.
# The hub picks #1 on private IPs or offline, and #2 when you open Crew on a public hostname while online.
# NEXT_PUBLIC_VDO_NINJA_URLS=http://192.168.1.50:3456,https://vdo.ninja
# Room password appended to every join/director/OBS link (&password). VDO: alphanumeric, 1–49 chars.
# NEXT_PUBLIC_VDO_NINJA_ROOM_PASSWORD=storyteller

# HR (directory + leave) runs inside crew-hub — grant `hr` / `hr_manage` in Users & permissions. Data: .data/leave-requests.json
