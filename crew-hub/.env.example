# Local dev uses port 38471 (see package.json). Docker maps host 38471 → container 3000 by default.

# Required: session signing (min 16 characters)
CREW_SESSION_SECRET=replace-with-a-long-random-secret
# Force Secure session cookies when you use HTTPS but the app does not see x-forwarded-proto: https.
# CREW_SESSION_COOKIE_SECURE=1

# --- Users (stored in .data/users.json) ---
# Fresh install: open /login — if there are no users, you’ll see “Create administrator account”.
# Optional: migrate legacy .data/members.json into users when the file is empty.
#
# Unattended seeding (Docker/CI): set CREW_SEED_FROM_ENV=1 to also create users from env:
# CREW_BOOTSTRAP_* / CREW_ADMIN_* / CREW_SUBCONTRACTOR_* (see below).
# CREW_SEED_FROM_ENV=1
#
# CREW_BOOTSTRAP_USERNAME=admin
# CREW_BOOTSTRAP_EMAIL=you@example.com
# CREW_BOOTSTRAP_PASSWORD_HASH='$2b$10$...'
#
# CREW_SUBCONTRACTOR_EMAIL=demo@crew.local
# CREW_SUBCONTRACTOR_PASSWORD_HASH='$2b$10$...'
# CREW_ADMIN_EMAIL=admin@crew.local
# CREW_ADMIN_PASSWORD_HASH='$2b$10$...'
# Optional recovery: CREW_ADMIN_PASSWORD=... syncs hash for CREW_ADMIN_EMAIL on each start.

# Billing follow-up cron: GET /api/billing/cron/followups?token=...
# CREW_BILLING_CRON_SECRET=

# Password reset emails (forgot password). Without SMTP, reset-by-email returns 503.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Crew <noreply@yourdomain.com>"
# NEXT_PUBLIC_CREW_PUBLIC_URL=https://your-crew.example.com

# Private iCal: GET /api/ical/combined?token=... (shifts + schedule), or /api/ical/shifts, /api/ical/calendar
# CREW_ICAL_TOKEN=
# CREW_ICAL_NAME=Crew Shifts
# CREW_ICAL_UID_DOMAIN=your.domain
# NEXT_PUBLIC_CREW_PUBLIC_URL=http://127.0.0.1:38471

# Optional: canonical room id — open first in Matrix channels when already joined (set on server; no rebuild).
# CREW_MATRIX_DEFAULT_ROOM_ID=!xxxxxxxx:localhost

# Embedded synapse-admin + Matrix (Channels) — one Synapse behind the hub; LAN IP vs public URL both use the same /_matrix proxy (same accounts).
# NEXT_PUBLIC_SERVICE_SYNAPSE_URL=http://127.0.0.1:18088
# NEXT_PUBLIC_MATRIX_HOMESERVER_URL=http://127.0.0.1:8008
# Proxy Matrix + Synapse admin API through this app (same-origin /_matrix, /_synapse) — fixes CORS / “fetch failed”. Restart after changing.
# MATRIX_UPSTREAM_URL=http://127.0.0.1:8008
#
# Element / Synapse user provisioning (optional): same username+password as Crew when admins create users.
# Requires MATRIX_UPSTREAM_URL + server admin token. Registration can remain off in Element.
# CREW_SYNAPSE_ADMIN_ACCESS_TOKEN=syt_xxxxxxxx
# CREW_SYNAPSE_SERVER_NAME=localhost

# Production video — VDO.Ninja embed + link generator (/comms/vdo). Baked at build time.
# NEXT_PUBLIC_VDO_NINJA_URL=https://vdo.ninja
# Multiple engines: LAN/self-hosted first, then public/cloud — auto-select prefers #1 on private IP or offline, #2 on public hostname when online.
# NEXT_PUBLIC_VDO_NINJA_URLS=http://192.168.1.50:3456,https://vdo.ninja
# Appended to every generated link (&password). Alphanumeric per VDO docs. Default in code: storyteller.
# NEXT_PUBLIC_VDO_NINJA_ROOM_PASSWORD=storyteller
